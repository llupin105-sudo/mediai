# MediAI — variables d'environnement (modèle).
# Copier en .env et remplir. NE JAMAIS committer le .env réel.
# Cette liste documente toute la surface de configuration : utile pour la
# migration d'hébergement (rien de spécifique à Render n'est requis).

# ── Base de données PostgreSQL (obligatoire) ──────────────────────────
DATABASE_URL=postgres://user:password@host:5432/mediai

# ── Authentification (obligatoire en production) ──────────────────────
# Chaîne aléatoire longue. En production, le serveur refuse de démarrer sans.
# Générer avec : openssl rand -base64 48
JWT_SECRET=

# ── IA — génération de comptes-rendus (Claude / Anthropic) ────────────
ANTHROPIC_API_KEY=
# Optionnel : surcharge le modèle par défaut (claude-sonnet-4-6)
CLAUDE_MODEL=

# ── IA — transcription audio (OpenAI Whisper) ─────────────────────────
# ⚠️ Conformité : à remplacer par une transcription auto-hébergée/UE (HDS).
OPENAI_API_KEY=

# ── Paiement (Stripe) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── Email transactionnel (Resend) ─────────────────────────────────────
RESEND_API_KEY=

# ── Connexion Google (optionnel) ──────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Divers ────────────────────────────────────────────────────────────
# NODE_ENV=production active le garde-fou JWT_SECRET (défini par l'image Docker).
NODE_ENV=production
# Port d'écoute (fourni par la plateforme d'hébergement).
PORT=3001
